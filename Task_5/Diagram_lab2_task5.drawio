        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Builder — створення героя і ворога\n\ninterface CharacterBuilderInterface {\n    +setName(name: string): self\n    +setHeight(height: int): self\n    +setBodyType(bodyType: string): self\n    +setHairColor(hairColor: string): self\n    +setEyeColor(eyeColor: string): self\n    +setClothes(clothes: string): self\n    +addInventoryItem(item: string): self\n    +build(): Character\n}\n\nclass Character {\n    -role: string\n    -name: string\n    -height: int\n    -bodyType: string\n    -hairColor: string\n    -eyeColor: string\n    -clothes: string\n    -inventory: array\n    -goodDeeds: array\n    -evilDeeds: array\n    -alignment: string\n    +setRole(role: string): void\n    +setName(name: string): void\n    +setHeight(height: int): void\n    +setBodyType(bodyType: string): void\n    +setHairColor(hairColor: string): void\n    +setEyeColor(eyeColor: string): void\n    +setClothes(clothes: string): void\n    +addInventoryItem(item: string): void\n    +addGoodDeed(deed: string): void\n    +addEvilDeed(deed: string): void\n    +setAlignment(alignment: string): void\n    +showInfo(): void\n}\n\nclass HeroBuilder {\n    -character: Character\n    -reset(): void\n    +setName(name: string): self\n    +setHeight(height: int): self\n    +setBodyType(bodyType: string): self\n    +setHairColor(hairColor: string): self\n    +setEyeColor(eyeColor: string): self\n    +setClothes(clothes: string): self\n    +addInventoryItem(item: string): self\n    +addGoodDeed(deed: string): self\n    +build(): Character\n}\n\nclass EnemyBuilder {\n    -character: Character\n    -reset(): void\n    +setName(name: string): self\n    +setHeight(height: int): self\n    +setBodyType(bodyType: string): self\n    +setHairColor(hairColor: string): self\n    +setEyeColor(eyeColor: string): self\n    +setClothes(clothes: string): self\n    +addInventoryItem(item: string): self\n    +addEvilDeed(deed: string): self\n    +build(): Character\n}\n\nclass CharacterDirector {\n    +createDreamHero(builder: HeroBuilder): Character\n    +createWorstEnemy(builder: EnemyBuilder): Character\n}\n\nHeroBuilder ..|&gt; CharacterBuilderInterface\nEnemyBuilder ..|&gt; CharacterBuilderInterface\n\nHeroBuilder --&gt; Character\nEnemyBuilder --&gt; Character\nCharacterDirector --&gt; HeroBuilder\nCharacterDirector --&gt; EnemyBuilder\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="wfDLLQgzaq5TWkA1-BC0-1">
