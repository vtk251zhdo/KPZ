        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Завдання 2. Abstract Factory — фабрика виробництва техніки\n\ninterface DeviceFactoryInterface {\n    +createLaptop(): LaptopInterface\n    +createNetbook(): NetbookInterface\n    +createEBook(): EBookInterface\n    +createSmartphone(): SmartphoneInterface\n}\n\ninterface LaptopInterface {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\ninterface NetbookInterface {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\ninterface EBookInterface {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\ninterface SmartphoneInterface {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass IPhoneFactory {\n    +createLaptop(): LaptopInterface\n    +createNetbook(): NetbookInterface\n    +createEBook(): EBookInterface\n    +createSmartphone(): SmartphoneInterface\n}\n\nclass XiaomiFactory {\n    +createLaptop(): LaptopInterface\n    +createNetbook(): NetbookInterface\n    +createEBook(): EBookInterface\n    +createSmartphone(): SmartphoneInterface\n}\n\nclass GalaxyFactory {\n    +createLaptop(): LaptopInterface\n    +createNetbook(): NetbookInterface\n    +createEBook(): EBookInterface\n    +createSmartphone(): SmartphoneInterface\n}\n\nclass IPhoneLaptop {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass IPhoneNetbook {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass IPhoneEBook {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass IPhoneSmartphone {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass XiaomiLaptop {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass XiaomiNetbook {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass XiaomiEBook {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass XiaomiSmartphone {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass GalaxyLaptop {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass GalaxyNetbook {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass GalaxyEBook {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nclass GalaxySmartphone {\n    +getBrand(): string\n    +getModel(): string\n    +getSpecs(): string\n}\n\nIPhoneFactory ..|&gt; DeviceFactoryInterface\nXiaomiFactory ..|&gt; DeviceFactoryInterface\nGalaxyFactory ..|&gt; DeviceFactoryInterface\n\nIPhoneLaptop ..|&gt; LaptopInterface\nIPhoneNetbook ..|&gt; NetbookInterface\nIPhoneEBook ..|&gt; EBookInterface\nIPhoneSmartphone ..|&gt; SmartphoneInterface\n\nXiaomiLaptop ..|&gt; LaptopInterface\nXiaomiNetbook ..|&gt; NetbookInterface\nXiaomiEBook ..|&gt; EBookInterface\nXiaomiSmartphone ..|&gt; SmartphoneInterface\n\nGalaxyLaptop ..|&gt; LaptopInterface\nGalaxyNetbook ..|&gt; NetbookInterface\nGalaxyEBook ..|&gt; EBookInterface\nGalaxySmartphone ..|&gt; SmartphoneInterface\n\nIPhoneFactory ..&gt; IPhoneLaptop : creates\nIPhoneFactory ..&gt; IPhoneNetbook : creates\nIPhoneFactory ..&gt; IPhoneEBook : creates\nIPhoneFactory ..&gt; IPhoneSmartphone : creates\n\nXiaomiFactory ..&gt; XiaomiLaptop : creates\nXiaomiFactory ..&gt; XiaomiNetbook : creates\nXiaomiFactory ..&gt; XiaomiEBook : creates\nXiaomiFactory ..&gt; XiaomiSmartphone : creates\n\nGalaxyFactory ..&gt; GalaxyLaptop : creates\nGalaxyFactory ..&gt; GalaxyNetbook : creates\nGalaxyFactory ..&gt; GalaxyEBook : creates\nGalaxyFactory ..&gt; GalaxySmartphone : creates\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="oeMHBtd-t9tdfScS_X7C-1">
